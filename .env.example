# Copie para .env.local e preencha os valores.

# Conexão PostgreSQL (formato URI ou variáveis separadas abaixo)
DATABASE_URL=postgresql://breshopping:breshopping@localhost:5432/breshopping_db

# Alternativa se não usar DATABASE_URL:
PG_HOST=localhost
PG_PORT=5432
PG_USER=breshopping
PG_PASSWORD=breshopping
PG_DATABASE=breshopping_db

# Segredo para assinatura JWT (sessão). Gere uma string longa e aleatória em produção.
JWT_SECRET=change-me-to-a-long-random-string-in-production

# URL pública da aplicação (usada em links e cookies em alguns ambientes)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Opcional: bucket/serviço de imagens (MVP usa URLs em product_images; preencha quando integrar Cloudinary/Supabase)
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_SECRET=
